DATABASE_URL=postgres://postgres@localhost:5432/ai_model_platform
JWT_SECRET=replace-with-local-dev-secret
ENCRYPTION_KEY=replace-with-32-byte-minimum-secret
API_PORT=4000
API_HOST=0.0.0.0
ADMIN_WEB_PORT=5173
CHECKOUT_WEB_PORT=5174
# Vite dev proxy target for LAN preview. Leave VITE_API_BASE empty to let browsers call
# same-origin /api and /v1 through the Vite proxy.
API_PROXY_TARGET=http://127.0.0.1:4000
VITE_API_BASE=
VITE_TOKEN_API_BASE=

# Payment production configuration template for ai-model-platform.
# Copy the needed keys into your real .env / deployment secret manager.
# Do not commit real private keys, API keys, merchant certs, or platform certs.

# ------------------------------------------------------------
# Shared payment/runtime settings
# ------------------------------------------------------------
APP_ENV=development
NODE_ENV=development
PUBLIC_API_BASE_URL=http://localhost:4000
CHECKOUT_WEB_BASE_URL=http://localhost:5174
PAYMENT_MOCK_ENABLED=true
PAYMENT_ORDER_EXPIRE_MINUTES=30
PAYMENT_CALLBACK_RAW_BODY_ENABLED=true

# Optional success/failure frontend pages. QR payment success is driven by frontend order polling,
# not by payment-provider browser redirects.
PAYMENT_SUCCESS_URL=http://localhost:5174/payment/success
PAYMENT_FAILURE_URL=http://localhost:5174/payment/failure

# ------------------------------------------------------------
# Alipay QR / alipay.trade.precreate
# ------------------------------------------------------------
ALIPAY_ENABLED=false
ALIPAY_ENV=sandbox
ALIPAY_APP_ID=
ALIPAY_PID=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_CHARSET=utf-8

# Choose exactly one key mode: cert or public_key.
# Production recommendation: cert.
ALIPAY_KEY_MODE=cert

# Recommended: mount files as secrets and reference paths.
ALIPAY_APP_PRIVATE_KEY_PATH=/run/secrets/alipay/app_private_key.pem
ALIPAY_APP_CERT_PATH=/run/secrets/alipay/appCertPublicKey.crt
ALIPAY_ALIPAY_CERT_PATH=/run/secrets/alipay/alipayCertPublicKey_RSA2.crt
ALIPAY_ALIPAY_ROOT_CERT_PATH=/run/secrets/alipay/alipayRootCert.crt

# Alternative for cloud envs that cannot mount files: base64 one-line PEM/cert contents.
# Leave empty when using *_PATH values.
ALIPAY_APP_PRIVATE_KEY_BASE64=
ALIPAY_APP_CERT_BASE64=
ALIPAY_ALIPAY_CERT_BASE64=
ALIPAY_ALIPAY_ROOT_CERT_BASE64=

# Only for ALIPAY_KEY_MODE=public_key. This is the Alipay public key generated/displayed
# by Alipay after you upload your app public key. It is not your app public key.
ALIPAY_ALIPAY_PUBLIC_KEY=

ALIPAY_NOTIFY_URL=http://localhost:4000/api/payment/webhooks/alipay
ALIPAY_QR_EXPIRE_MINUTES=30

# ------------------------------------------------------------
# WeChat Pay API v3 Native QR / /v3/pay/transactions/native
# ------------------------------------------------------------
WECHAT_PAY_ENABLED=false
WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=

# Recommended: mount merchant private key and platform certificate as files.
WECHAT_PAY_MERCHANT_PRIVATE_KEY_PATH=/run/secrets/wechat/apiclient_key.pem
WECHAT_PAY_PLATFORM_CERT_PATH=/run/secrets/wechat/wechatpay_platform.pem
WECHAT_PAY_PLATFORM_CERT_SERIAL_NO=

# Alternative for cloud envs that cannot mount files: base64 one-line PEM/cert contents.
# Leave empty when using *_PATH values.
WECHAT_PAY_MERCHANT_PRIVATE_KEY_BASE64=
WECHAT_PAY_PLATFORM_CERT_BASE64=

# Optional if using WeChat Pay public-key mode instead of platform-certificate mode.
WECHAT_PAY_PLATFORM_PUBLIC_KEY_ID=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_BASE64=

WECHAT_PAY_NOTIFY_URL=http://localhost:4000/api/payment/webhooks/wechat
WECHAT_PAY_REFUND_NOTIFY_URL=http://localhost:4000/api/payment/webhooks/wechat/refund
WECHAT_PAY_NATIVE_EXPIRE_MINUTES=30

# ------------------------------------------------------------
# Apple IAP / App Store Server API
# ------------------------------------------------------------
APPLE_IAP_BUNDLE_ID=
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY_PATH=/run/secrets/apple/AuthKey_KEYID.p8
APPLE_IAP_PRIVATE_KEY_BASE64=
APPLE_IAP_ENV=Sandbox
APPLE_IAP_NOTIFICATION_SHARED_SECRET=
